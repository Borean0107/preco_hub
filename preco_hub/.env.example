# Variáveis de Ambiente - Preço Hub
# Copie este arquivo para .env e preencha com suas credenciais

# Banco de Dados
DB_HOST=localhost
DB_NAME=preco_hub
DB_USER=root
DB_PASS=

# Aplicação
APP_ENV=development
APP_DEBUG=false

# Upload de Arquivos (em MB)
MAX_UPLOAD_SIZE=5

# Sessão
SESSION_NAME=PRECOHUB_SESSION
SESSION_LIFETIME=3600
