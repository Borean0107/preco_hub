# Proteger acesso direto ao backend
# Apenas requisições AJAX/API são permitidas

# Ativar mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Bloquear acesso direto a arquivos específicos
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_FILENAME} !\.php$
    RewriteRule ^(.+)$ - [F,L]
</IfModule>

# Negar acesso direto a arquivos de configuração
<FilesMatch "^(config|middleware)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^(db\.php|response\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Proteger diretórios específicos
<Directory "config">
    Order Allow,Deny
    Deny from all
</Directory>

<Directory "middleware">
    Order Allow,Deny
    Deny from all
</Directory>

<Directory "helpers">
    Order Allow,Deny
    Deny from all
</Directory>

# Não indexar diretórios
Options -Indexes

# Headers de segurança
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
